# ─────────────────────────────────────────────────────────────────────────────
# .env.example — reference template for the environment variables this project
# uses. Copy it to `.env` and fill in the values for the site/project you are
# developing against (most commonly a Vercel-hosted deployment):
#
#     cp .env.example .env
#
# Then, optionally, create `.env.local` to override individual keys for local
# development (e.g. NEXT_PUBLIC_SITE_URL=http://localhost:3000). `.env.local` is
# loaded after `.env` and wins on any overlapping key.
#
# Load order (later wins):  .env  →  .env.local
# `.env` and `.env.local` are gitignored; only this `.env.example` is committed.
# ─────────────────────────────────────────────────────────────────────────────

# ── Public site URL ──────────────────────────────────────────────────────────
# The canonical origin of the site, with NO trailing slash. Exposed to the
# browser (NEXT_PUBLIC_ prefix). Used to build <link rel="canonical"> hrefs,
# JSON-LD pageUrl values, robots.txt, sitemap.xml and llms.txt. When unset, the
# app falls back to the incoming request Host header.
#   prod example:  https://your-site.vercel.app
#   local (.env.local): http://localhost:3000
NEXT_PUBLIC_SITE_URL=

# ── Optimizely Graph (cms-sdk) ───────────────────────────────────────────────
# Single-key API token for Optimizely Content Graph. Required: GraphClient and
# the site search endpoint throw if this is unset. Determines which CMS
# instance's published/preview content the front end reads.
OPTIMIZELY_GRAPH_SINGLE_KEY=
# Graph management keys (App Key + Secret) from CMS → Graph → Management Keys.
# Used for HMAC-authenticated Graph requests (e.g. authenticated/preview
# queries). Optional — the front end runs on the single key alone. These are
# Graph credentials only; they do NOT grant CMS Content Management API access.
OPTIMIZELY_GRAPH_APP_KEY=
OPTIMIZELY_GRAPH_SECRET=

# ── Optimizely CMS instance URL ──────────────────────────────────────────────
# Full URL of the CMS UI host for this instance, e.g.
# https://app-xxxxxxxx.cms.optimizely.com/ . Used to derive image/asset remote
# patterns (next.config) and to build Visual Builder preview/edit deep-links.
# NOTE: the cms-cli does NOT read this — it routes pushes using the client
# credentials below; this is for the Next.js app and reference only.
OPTIMIZELY_CMS_URL=

# Optional public override of the CMS URL, exposed to the browser for the draft/
# preview layer. Falls back to OPTIMIZELY_CMS_URL when unset — leave blank
# unless the browser needs a different host than the server does.
NEXT_PUBLIC_CMS_URL=

# ── Optimizely CMS OAuth client (cms-cli) ────────────────────────────────────
# Client ID / secret for the cms-cli used by `yarn cms:push` and `yarn cms:pull`
# to sync TypeScript content-type and display-template definitions. These
# credentials alone determine WHICH CMS instance the push/pull targets, so
# make sure they match the instance in OPTIMIZELY_GRAPH_SINGLE_KEY above.
# Not needed at runtime — only for the sync CLI.
OPTIMIZELY_CMS_CLIENT_ID=
OPTIMIZELY_CMS_CLIENT_SECRET=

# ── Opti-Admin dashboard (optional) ──────────────────────────────────────────
# Credentials for the built-in /opti-admin sign-in. If EITHER is unset, the
# admin login is disabled (the auth endpoint reports "not configured"). Leave
# blank to keep the admin dashboard turned off.
OPTI_ADMIN_USER=
OPTI_ADMIN_PASSWORD=

# ── Optimizely CMP preview integration (optional) ────────────────────────────
# Powers the /cmp-preview blog preview driven by CMP's content_preview_requested
# webhook (handler: app/api/cmp-preview/route.ts).
#   CMP_CLIENT_ID / CMP_CLIENT_SECRET — OAuth2 client-credentials app from CMP
#     (Settings → Apps). Used to mint a Bearer token for the acknowledge/complete
#     callbacks and to resolve library-asset images to public CDN URLs.
#   CMP_CALLBACK_SECRET — the shared secret entered when creating the CMP webhook;
#     CMP sends it as the `callback-secret` header so inbound webhooks can be
#     verified. If unset, the webhook still captures/renders but skips verification
#     and the acknowledge/complete round-trip.
CMP_CLIENT_ID=
CMP_CLIENT_SECRET=
CMP_CALLBACK_SECRET=
# CMS container key (no dashes) new blog pages are created under when CMP
# publishes (asset_published). Must be a _page/_experience container in the SAME
# instance OPTIMIZELY_CMS_CLIENT_ID/SECRET target. The CMS create/update reuses
# those CMS credentials — no extra auth needed.
CMP_BLOG_CONTAINER_KEY=

# ── Durable preview store (Vercel KV / Upstash) ──────────────────────────────
# Required for the production CMP preview flow — CMP fetches the completed
# preview URL later, on a possibly-different serverless instance, so captured
# content must be durable (not in-memory). Provision Vercel KV (Storage tab);
# Vercel injects these automatically. Without them the store falls back to
# in-memory (works in `yarn dev`, not reliable on Vercel).
KV_REST_API_URL=
KV_REST_API_TOKEN=
